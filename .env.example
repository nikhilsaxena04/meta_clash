# ==============================================================================
# Meta Clash - Environment Configuration Template
# Copy this file to '.env' (for local development) or set these in your hosting environment (e.g. Render / Docker)
# ==============================================================================

# ------------------------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------------------------
PORT=8080
DATABASE_URL=postgres://postgres:postgrespassword@db:5432/meta_clash?sslmode=disable
JWT_SECRET=super_secret_dev_key_12345
JWT_EXPIRY=24h
JIKAN_BASE_URL=https://api.jikan.moe/v4
JIKAN_TIMEOUT=5s

# Gemini API Key (Required for anime card stat generation & lore text)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ------------------------------------------------------------------------------
# Frontend Configuration (Used dynamically at runtime via window.__ENV__)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/api/ws
